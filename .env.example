# DeepSeek API 学习项目 - 配置文件
# 声明：本项目完全由 AI 生成，仅供个人学习研究使用
# 复制此文件为 .env 并填入你的配置

# ============================================================
# 登录配置 (二选一)
# ============================================================

# 方式1: 使用 Token
# 获取方法:
#   1. 打开 https://chat.deepseek.com
#   2. 登录账号
#   3. F12 打开开发者工具
#   4. Console 执行: JSON.parse(localStorage.getItem('userToken')).value
#   5. 复制返回的字符串
DEEPSEEK_TOKEN=

# 方式2: 使用邮箱密码登录
# Token 为空时使用此方式
# 支持邮箱或手机号 (手机号自动添加 +86 区号)
DEEPSEEK_EMAIL=
DEEPSEEK_PASSWORD=

# ============================================================
# 服务器配置
# ============================================================

# 监听地址 (0.0.0.0 表示所有网卡)
SERVER_HOST=0.0.0.0

# 监听端口
SERVER_PORT=8000

# ============================================================
# 安全配置 (可选)
# ============================================================

# API Key (用于保护你的服务)
# 设置后，客户端调用时需要提供此 Key
# Cherry Studio 中填写到 "API 密钥" 字段
API_KEY=
